---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products } from "../../data/products";
---

<BaseLayout>
  <section>
    <h2>PRODUCTS</h2>

    <div class="product-list">
      {products.map((p, i) => (
        <a class="product-feature" href={p.url} target="_blank" rel="noopener noreferrer">
          <figure class="feature-figure">
            <img
              src={p.image}
              alt={p.title}
              loading="lazy"
              onerror="this.closest('figure').remove()"
            />
            <figcaption>Fig. {String(i + 1).padStart(2, "0")}</figcaption>
          </figure>

          <div class="feature-body">
            <span class="feature-index">No. {String(i + 1).padStart(2, "0")}</span>
            <h3>{p.title}</h3>

            {p.techStack && p.techStack.length > 0 && (
              <p class="byline">{p.techStack.join(" / ")}</p>
            )}

            <p class="description">{p.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <style>
    .product-list {
      margin-top: 2rem;
      border-top: 2px solid var(--rule);
    }

    .product-feature {
      display: flex;
      gap: 2rem;
      align-items: flex-start;
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--rule);
      text-decoration: none;
      color: inherit;
    }

    .feature-figure {
      flex: 0 0 50%;
      margin: 0;
    }

    .feature-figure img {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 3 / 2;
      object-fit: cover;
      border: 1px solid var(--rule);
      filter: grayscale(100%) contrast(1.05);
      transition: filter 0.3s ease;
    }

    .product-feature:hover .feature-figure img {
      filter: grayscale(0%);
    }

    .feature-figure figcaption {
      margin-top: 0.4rem;
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.75rem;
      text-align: center;
      color: var(--fg);
      opacity: 0.6;
    }

    .feature-body {
      flex: 1;
      min-width: 0;
    }

    .feature-index {
      display: block;
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.8rem;
      letter-spacing: 1px;
      color: var(--fg);
      opacity: 0.6;
      margin-bottom: 0.3rem;
    }

    .feature-body h3 {
      margin: 0 0 0.5rem 0;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.6rem;
      color: var(--fg);
    }

    .byline {
      margin: 0 0 0.8rem 0;
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.85rem;
      letter-spacing: 0.5px;
      color: var(--fg);
      opacity: 0.7;
    }

    .description {
      margin: 0;
      line-height: 1.8;
      font-size: 0.95rem;
      color: var(--fg);
      max-width: 60ch;
    }

    @media (max-width: 640px) {
      .product-feature {
        flex-direction: column;
        gap: 1rem;
      }

      .feature-figure {
        flex: none;
        width: 100%;
      }

      .feature-figure img {
        width: 100%;
        height: auto;
        aspect-ratio: 2 / 1;
      }

      .feature-body h3 {
        font-size: 1.3rem;
      }
    }
  </style>
</BaseLayout>
