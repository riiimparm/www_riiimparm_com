---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTools } from "../../lib/tools";

const tools = await getTools();
---

<BaseLayout>
  <section>
    <h2>TOOLS</h2>

    <ul class="tools-list">
      {tools.map((tool) => (
        <li>
          <a href={`/tools/${tool.slug}/`}>{tool.title}</a>
          {tool.description && (
            <p class="tool-description">{tool.description}</p>
          )}
        </li>
      ))}
    </ul>
  </section>

  <style>
    .tools-list {
      list-style: none;
      margin: 1.5rem 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .tools-list a {
      color: var(--fg);
      text-decoration: none;
      font-size: 1rem;
      text-shadow: 0 0 0 transparent;
      transition: color 0.6s ease 0.15s, text-shadow 0.6s ease 0.15s;
    }

    .tools-list a:hover {
      color: var(--accent);
      text-decoration: underline;
      text-shadow: 0 0 8px rgba(var(--accent-rgb), 0.5);
    }

    .tool-description {
      margin: 0.2rem 0 0;
      color: var(--fg);
      opacity: 0.7;
      font-size: 0.85rem;
      line-height: 1.6;
    }
  </style>
</BaseLayout>