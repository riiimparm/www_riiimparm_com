---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteData } from "../data/index";
---

<BaseLayout>
  <section>
    <h2>ABOUT</h2>
    <p set:html={siteData.about.replace(/\n/g, '<br />')} />
  </section>

  <section>
    <h2>SITE NAVIGATION</h2>
    <div class="site-navigation" role="navigation" aria-label="site navigation">
      <div class="nav-links">
        {siteData.navigation.map((link) => (
          <a href={link.href} class="nav-link">{link.label}</a>
        ))}
      </div>
    </div>
  </section>

  <section>
    <h2>LINKS</h2>
    <div class="links" role="navigation" aria-label="social links">
      {siteData.socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="social-link">
          <img src={link.iconUrl} alt={link.label} class="link-icon link-icon-base" />
          <img src={link.iconUrlHover} alt="" aria-hidden="true" class="link-icon link-icon-hover" />
        </a>
      ))}
    </div>
  </section>
</BaseLayout>