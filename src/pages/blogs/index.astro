---
import BaseLayout from "../../layouts/BaseLayout.astro";

const BLOG_URL = "https://www.rowicy.com/blog/author/riiim/";
---

<BaseLayout>
    <section>
        <h2>Posts</h2>
        <p>
            ブログは外部サイトに移行しました。
            自動的に開かない場合は
            <a href={BLOG_URL} target="_blank" rel="noopener noreferrer">こちら</a>
            をクリックしてください。
        </p>
    </section>

    <script define:vars={{ BLOG_URL }}>
        window.open(BLOG_URL, "_blank", "noopener,noreferrer");
        window.location.replace("/");
    </script>
</BaseLayout>
