---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSlides } from "../../lib/slides";

const slides = await getSlides();
---

<BaseLayout>
  <section>
    <h2>SLIDES</h2>

    <div class="slides-grid">
      {slides.map((slide) => (
        <a class="slide-item" href={`/slides/${slide.slug}/`}>
          <div class="slide-thumbnail">
            <img src={slide.imageUrl} alt={slide.title} loading="lazy" />
            <div class="slide-overlay">
              <span class="view-text">View Details</span>
            </div>
          </div>
          <h3 class="slide-title">{slide.title}</h3>
          <time class="slide-date">
            {slide.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}
          </time>
        </a>
      ))}
    </div>
  </section>

  <style>
    .slides-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 1.5rem;
    }

    .slide-item {
      display: block;
      border: 1px solid var(--rule);
      background: transparent;
      text-decoration: none;
      transition: background 0.5s ease 0.15s, border-color 0.5s ease 0.15s, box-shadow 0.5s ease 0.15s, transform 0.3s ease;
      overflow: hidden;
    }

    .slide-item:hover {
      background: rgba(var(--accent-rgb), 0.08);
      border-color: var(--accent);
      box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.2);
      transform: translateY(-2px);
      text-decoration: none;
    }

    .slide-thumbnail {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: rgba(0, 0, 0, 0.05);
    }

    .slide-thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .slide-item:hover .slide-thumbnail img {
      transform: scale(1.05);
    }

    .slide-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .slide-item:hover .slide-overlay {
      opacity: 1;
    }

    .view-text {
      color: var(--accent);
      font-size: 1.1rem;
      font-weight: bold;
    }

    .slide-title {
      font-size: 1rem;
      font-weight: bold;
      color: var(--fg);
      text-shadow: 0 0 0 transparent;
      transition: color 0.5s ease 0.15s, text-shadow 0.5s ease 0.15s;
      margin: 0;
      padding: 1rem 1rem 0.5rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .slide-item:hover .slide-title {
      color: var(--accent);
      text-shadow: 0 0 8px rgba(var(--accent-rgb), 0.45);
    }

    .slide-date {
      display: block;
      font-size: 0.85rem;
      color: var(--fg);
      opacity: 0.6;
      transition: color 0.5s ease 0.15s, opacity 0.5s ease 0.15s;
      padding: 0 1rem 1rem;
    }

    .slide-item:hover .slide-date {
      color: var(--accent);
      opacity: 0.85;
    }

    @media (max-width: 768px) {
      .slides-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1.5rem;
      }
    }
  </style>
</BaseLayout>
