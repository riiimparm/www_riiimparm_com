---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSlides } from "../../lib/slides";

export async function getStaticPaths() {
  const slides = await getSlides();
  return slides.map((slide) => ({
    params: { slug: slide.slug },
    props: { slide },
  }));
}

const { slide } = Astro.props;
const formattedDate = slide.pubDate.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<BaseLayout title={slide.title} minimal backLabel="← Slides" backHref="/slides/">
  {slide.pdfUrl ? (
    <div class="pdf-stage">
      <canvas id="pdfCanvas"></canvas>
      <div class="pdf-page-count" id="pdfPageCount"></div>
    </div>
  ) : (
    <div class="embed-stage">
      {slide.slideId && (
        <iframe
          class="speakerdeck-iframe"
          src={`https://speakerdeck.com/player/${slide.slideId}`}
          title={slide.title}
          frameborder="0"
          allowfullscreen
        ></iframe>
      )}
      <div class="embed-info">
        <h1 class="embed-title">{slide.title}</h1>
        <time class="embed-date">{formattedDate}</time>
        <a class="embed-link" href={slide.link} target="_blank" rel="noopener noreferrer">SpeakerDeckで見る →</a>
      </div>
    </div>
  )}

  <style>
    .pdf-stage {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      background: #000;
    }

    .pdf-stage canvas {
      max-width: 100%;
      max-height: 100%;
      box-shadow: 0 0 30px rgba(0, 0, 0, 0.6);
    }

    .pdf-page-count {
      position: absolute;
      bottom: 1rem;
      left: 50%;
      transform: translateX(-50%);
      color: #fff;
      opacity: 0.7;
      font-size: 0.85rem;
      letter-spacing: 0.5px;
    }

    .embed-stage {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      padding: 2rem;
    }

    .speakerdeck-iframe {
      width: 100%;
      max-width: 900px;
      aspect-ratio: 560 / 315;
      border: none;
    }

    .embed-info {
      text-align: center;
    }

    .embed-title {
      font-size: 1.1rem;
      margin: 0 0 0.5rem;
    }

    .embed-date {
      display: block;
      opacity: 0.7;
      font-size: 0.85rem;
      margin-bottom: 0.75rem;
    }

    .embed-link {
      color: var(--accent);
    }
  </style>

  {slide.pdfUrl && (
    <script define:vars={{ pdfUrl: slide.pdfUrl }}>
      document.addEventListener('DOMContentLoaded', () => {
        const pdfCanvas = document.getElementById('pdfCanvas');
        const pdfPageCount = document.getElementById('pdfPageCount');

        let pdfjsLib = null;
        let pdfDoc = null;
        let currentPage = 1;
        let rendering = false;

        const loadPdfjs = async () => {
          if (pdfjsLib) return pdfjsLib;
          const lib = await import('https://cdn.jsdelivr.net/npm/pdfjs-dist@4.6.82/build/pdf.min.mjs');
          lib.GlobalWorkerOptions.workerSrc = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.6.82/build/pdf.worker.min.mjs';
          pdfjsLib = lib;
          return lib;
        };

        const renderPage = async (num) => {
          if (!pdfDoc || rendering) return;
          rendering = true;
          const page = await pdfDoc.getPage(num);
          const ctx = pdfCanvas.getContext('2d');

          const baseViewport = page.getViewport({ scale: 1 });
          const fitScale = Math.min(
            window.innerWidth / baseViewport.width,
            window.innerHeight / baseViewport.height
          );
          const pixelRatio = window.devicePixelRatio || 1;
          const viewport = page.getViewport({ scale: fitScale * pixelRatio });

          pdfCanvas.width = viewport.width;
          pdfCanvas.height = viewport.height;
          pdfCanvas.style.width = `${viewport.width / pixelRatio}px`;
          pdfCanvas.style.height = `${viewport.height / pixelRatio}px`;

          await page.render({ canvasContext: ctx, viewport }).promise;
          pdfPageCount.textContent = `${num} / ${pdfDoc.numPages}`;
          rendering = false;
        };

        const goToPage = (num) => {
          if (!pdfDoc) return;
          if (num < 1 || num > pdfDoc.numPages) return;
          currentPage = num;
          renderPage(currentPage);
        };

        (async () => {
          const lib = await loadPdfjs();
          pdfDoc = await lib.getDocument(pdfUrl).promise;
          currentPage = 1;
          renderPage(currentPage);
        })();

        window.addEventListener('resize', () => {
          if (pdfDoc) renderPage(currentPage);
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            window.location.href = '/slides/';
          } else if (e.key === ' ' || e.key === 'Enter' || e.key === 'ArrowRight' || e.key === 'ArrowDown') {
            e.preventDefault();
            goToPage(currentPage + 1);
          } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            e.preventDefault();
            goToPage(currentPage - 1);
          }
        });
      });
    </script>
  )}
</BaseLayout>
